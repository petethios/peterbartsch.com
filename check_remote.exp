#!/usr/bin/expect -f
set timeout 10
set sftp_host "peterbartsch.com"
set sftp_user "tronicadmin"
set sftp_pass {X!!RBeHV}

spawn ssh ${sftp_user}@${sftp_host} "ls -la"
expect {
    -re ".*assword:" { 
        send "${sftp_pass}\r"
        exp_continue
    }
    "$ " {
        send "ls -la peterbartsch.com\r"
        expect "$ "
        send "exit\r"
    }
}
expect eof
